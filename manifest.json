{
  "manifest_version": 3,
  "name": "JobFilter - Company Blacklist",
  "version": "1.0.0",
  "description": "Hide job postings from companies you do not want to see, starting with LinkedIn.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_title": "JobFilter",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
