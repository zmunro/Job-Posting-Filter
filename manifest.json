{
  "manifest_version": 3,
  "name": "JobFilter - Company Blocklist",
  "version": "1.1.0",
  "description": "Hide job postings from companies you do not want to see on LinkedIn and Built In.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://builtin.com/*",
    "https://www.builtin.com/*",
    "https://*.builtin.com/*"
  ],
  "action": {
    "default_title": "JobFilter",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://builtin.com/*",
        "https://www.builtin.com/*",
        "https://*.builtin.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
